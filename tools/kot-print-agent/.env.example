# Base URL of the deployed site (no trailing slash)
SERVER_URL=https://your-site.com

# Shared secret. Must match PRINT_AGENT_TOKEN set on the server.
PRINT_AGENT_TOKEN=change-me-to-a-long-random-string

# Windows printer name as it appears in Devices & Printers
PRINTER_NAME=POS-80

# Seconds between polls
POLL_INTERVAL=5

# Header printed at the top of each ticket
SHOP_NAME=SOCHMAT
