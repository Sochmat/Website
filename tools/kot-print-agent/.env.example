# Base URL of the deployed site (no trailing slash)
SERVER_URL=https://your-site.com

# Shared secret. Must match PRINT_AGENT_TOKEN set on the server.
PRINT_AGENT_TOKEN=change-me-to-a-long-random-string

# Windows printer name as it appears in Devices & Printers
PRINTER_NAME=POS-80

# Seconds between polls
POLL_INTERVAL=5

# Header printed at the top of each ticket
SHOP_NAME=SOCHMAT

# "From: <source>" line at the very top of the ticket
ORDER_SOURCE=Website

# Legal numbers printed on tickets/bills (leave blank to omit)
FSSAI_NO=
GST_NO=

# --- Customer bill only ---
# Legal/brand name printed at the top of the bill
SHOP_LEGAL_NAME=Sochmat - by fitfuel
# Contact + address printed in the bill footer (leave blank to omit)
SHOP_CONTACT=
SHOP_ADDRESS=
# Name shown next to "Cashier:" on the bill
CASHIER=biller
# Bill line spacing in dots (printer default ~30; lower = more compact). Keep
# above ~18 so font B text (17 dots tall) does not overlap.
# (Only used when BILL_AS_IMAGE=0.)
BILL_LINE_SPACING=22

# The bill is printed as an image so its font can be smaller than the printer's
# built-in fonts. Lower BILL_FONT_PX = smaller text. Preview a size without a
# printer:  python print_agent.py --save-bill-image sample.png
BILL_AS_IMAGE=1
BILL_FONT_PX=17
# Printer printable width in dots (576 for most 80mm heads; try 512 if cut off).
BILL_IMG_WIDTH=576
