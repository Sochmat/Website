# Base URL of the deployed site (no trailing slash)
SERVER_URL=https://your-site.com

# Shared secret. Must match PRINT_AGENT_TOKEN set on the server.
PRINT_AGENT_TOKEN=change-me-to-a-long-random-string

# Windows printer name as it appears in Devices & Printers
PRINTER_NAME=POS-80

# Seconds between polls
POLL_INTERVAL=5

# Header printed at the top of each ticket
SHOP_NAME=SOCHMAT

# "From: <source>" line at the very top of the ticket
ORDER_SOURCE=Website

# Legal numbers printed on tickets/bills (leave blank to omit)
FSSAI_NO=
GST_NO=

# --- Customer bill only ---
# Legal/brand name printed at the top of the bill
SHOP_LEGAL_NAME=Sochmat - by fitfuel
# Contact + address printed in the bill footer (leave blank to omit)
SHOP_CONTACT=
SHOP_ADDRESS=
# Name shown next to "Cashier:" on the bill
CASHIER=biller
